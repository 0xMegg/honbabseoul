# Copy this file to `.env.local` (gitignored) and fill in the blanks.
# Never commit `.env.local`.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL — shown as "Project URL" under Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Publishable key — safe to expose in the browser bundle (subject to RLS).
# Prefer the new `sb_publishable_...` key from Supabase Dashboard
# Settings → API Keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon public key fallback. Keep only until every environment has moved
# to NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret API key — bypasses RLS. Server-only (Route Handlers, Server Actions,
# scripts). Prefer the new `sb_secret_...` key from Supabase Dashboard
# Settings → API Keys. Must NEVER be imported from a "use client" module.
SUPABASE_SECRET_KEY=

# Legacy service_role key fallback. Keep only until every environment has moved
# to SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# Project reference id (the subdomain of SUPABASE_URL) — used by the Supabase CLI.
SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Supabase — direct Postgres connection (server-only)
# -----------------------------------------------------------------------------
# Used by `pnpm db:push` / `pnpm db:reset` to apply migrations via psql.
# Fetch from Supabase Dashboard → Settings → Database → Connection string → URI.
# The pooler ("Transaction" mode) URL is fine for migration application.
# NEVER paste the value into chat — same exposure model as service_role.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Naver Maps (Web Dynamic Map)
# -----------------------------------------------------------------------------
# Client ID issued by NCP → Services → AI·Application Service → Maps.
# Public value; real protection is the URL whitelist on the NCP console.
NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID=
